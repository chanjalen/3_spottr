{
  "expo": {
    "name": "Spottr",
    "slug": "spottr",
    "owner": "spottr123",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4FC3E0"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "app.spottr.mobile",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.spottr.mobile",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.265741649084-vabnoi82qr737r6fk6d1b462mb7qo9vv"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4FC3E0"
      },
      "package": "app.spottr.mobile"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4FC3E0",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a4ef3539-a6f7-405d-ac11-ef7a72dec022"
      }
    }
  }
}
