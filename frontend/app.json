              "com.googleusercontent.apps.265741649084-vabnoi82qr737r6fk6d1b462mb7qo9vv"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4FC3E0"
      },
      "package": "com.spottr.app"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "2f119204-6d9e-4f6e-8052-b040e2ab5349"
      }
