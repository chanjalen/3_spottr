# Spottr Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to version control

# Django Settings
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database (for production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=spottr
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Allowed Hosts (comma-separated for production)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# API Keys
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# STRIPE_API_KEY=your_stripe_api_key_here

# Email Configuration — Resend SMTP relay (https://resend.com)
# Sign up, verify your domain, create an API key, then fill these in.
# Leave EMAIL_HOST blank to fall back to console output in dev.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=re_your_api_key_here

# Supabase S3 Storage
# Get these from Supabase Dashboard > Settings > Storage > S3 Connection
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key
SUPABASE_S3_BUCKET=Media_Uploads
